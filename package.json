{
  "name": "stylemirror-codebase",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspace @stylemirror/mobile",
    "test:style-engine": "npm test --workspace @stylemirror/style-engine",
    "start:mobile": "npm run start --workspace @stylemirror/mobile",
    "android:mobile": "npm run android --workspace @stylemirror/mobile",
    "android:mobile:release": "npm run android:release --workspace @stylemirror/mobile"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3"
  }
}
